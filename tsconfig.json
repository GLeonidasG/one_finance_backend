{
  "compilerOptions": {
    "module": "NodeNext", 
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "pretty": true,
    "skipLibCheck": true
  },
  "exclude": [
    "./node_modules",
    "./dist"
  ]
}
